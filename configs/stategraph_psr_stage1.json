{
  "name": "StateGraph-PSR Lite Stage 1",
  "cache_schema_version": 2,
  "label_contract": "action_segmentation_plus_multicomponent_completion",
  "procedure_schema": "configs/procedure_schemas/industreal_v1.json",
  "features": {
    "preferred_motion": "cached VideoMAEv2-giant SSv2, 1408-d",
    "fallback_motion": "frozen torchvision Swin3D-S, 768-d",
    "appearance": "frozen ConvNeXt-Tiny center-frame state feature, 768-d",
    "sensor": "hands + gaze + head pose, padded to 128-d",
    "clip_frames": 16,
    "clip_span_frames": 32,
    "stride_frames": 5,
    "fps": 10
  },
  "model": {
    "hidden_dim": 192,
    "num_temporal_blocks": 8,
    "attention_every": 2,
    "num_heads": 4,
    "dropout": 0.2,
    "graph_strength": 1.5,
    "composition_strength": 1.0,
    "num_components": 11,
    "completion_components": 10,
    "event_outcomes": ["correct", "incorrect", "remove"]
  },
  "training": {
    "precision": "bf16",
    "batch_size": 2,
    "accumulation_steps": 8,
    "sequence_length": 256,
    "sequence_stride": 192,
    "epochs": 80,
    "patience": 15,
    "learning_rate": 0.0003,
    "weight_decay": 0.001,
    "rare_window_boost": 4.0,
    "completion_pos_weight_cap": 100.0
  }
}
